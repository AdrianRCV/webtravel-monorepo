# ===========================================
# DATABASE CONFIGURATION
# ===========================================
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=webtravel

# ===========================================
# API CONFIGURATION
# ===========================================
# Admin user credentials (created on first run)
ADMIN_EMAIL=admin@webtravel.com
ADMIN_PASSWORD=change_me_to_a_strong_password
ADMIN_NAME=Administrador Principal

# Email service (Resend)
RESEND_API_KEY=your_resend_api_key_here
MAIL_FROM=noreply@webtravel.com

# Frontend URL (for email links)
FRONTEND_URL=http://localhost:3000

# ===========================================
# FRONTEND CONFIGURATION
# ===========================================
# Public API URL (accessed from browser)
NEXT_PUBLIC_API_URL=http://localhost:3001

# NextAuth configuration
AUTH_SECRET=generate_with_openssl_rand_base64_32
AUTH_GOOGLE_ID=your-google-client-id.apps.googleusercontent.com
AUTH_GOOGLE_SECRET=your-google-client-secret
AUTH_URL=http://localhost:3000

# Admin emails (comma-separated)
ADMIN_EMAILS=admin@webtravel.com
